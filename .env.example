# crawl-budget-analyser — copy to .env. The analyser is keyless; all optional.

# Where to store the audit-log SQLite DB (defaults to webapp/audit_log.db).
# AUDIT_LOG_PATH=

# Optional: your own SerpAPI key for real Google/Bing indexed page counts per
# section (see DEPLOY.md). Bring your own; omit to skip that enrichment.
# SERPAPI_KEY=
